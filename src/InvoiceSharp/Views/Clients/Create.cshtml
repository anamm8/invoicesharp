@model InvoiceSharp.Models.ClientModel

@{
    // Define o título da página
    ViewData["Title"] = "Criar Cliente";
}

<!-- Container Bootstrap -->
<div class="container mt-4">

    <!-- Card -->
    <div class="card shadow">

        <!-- Cabeçalho -->
        <div class="card-header bg-primary text-white">
            <h3>Criar Cliente</h3>
        </div>

        <div class="card-body">

            <!-- Formulário -->
            <form method="post" action="/Clients/Create">

                @Html.AntiForgeryToken()

                <!-- Nome -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>

                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Ex: Rafael" />

                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>

                    <input asp-for="Email"
                           type="email"
                           class="form-control"
                           placeholder="exemplo@email.com" />

                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- NIF -->
                <div class="mb-3">
                    <label asp-for="NIF" class="form-label"></label>

                    <input asp-for="NIF"
                           class="form-control"
                           placeholder="123456789" />

                    <span asp-validation-for="NIF" class="text-danger"></span>
                </div>

                <!-- Morada -->
                <div class="mb-3">
                    <label asp-for="Address" class="form-label"></label>

                    <input asp-for="Address"
                           class="form-control"
                           placeholder="Rua, nº, cidade" />

                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <!-- Telefone -->
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label"></label>

                    <input asp-for="Phone"
                           class="form-control"
                           placeholder="912345678" />

                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- Botões -->
                <button type="submit" class="btn btn-success">
                    Guardar Cliente
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>

            </form>

        </div>
    </div>

</div>