@model InvoiceSharp.Models.InvoiceModel

@{
    ViewData["Title"] = "Criar Fatura";
}

<div class="container mt-4">
    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3>Criar Fatura</h3>
        </div>

        <div class="card-body">

            <!-- mostra erros gerais -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <form asp-controller="Invoice" asp-action="Create" method="post">

                <!-- CLIENTE -->
                <div class="mb-3">
                    <label asp-for="ClientId" class="form-label"></label>

                    <select asp-for="ClientId" class="form-control">
                        <option value="">-- Selecionar Cliente --</option>

                        @foreach (var c in ViewBag.Clients)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>

                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <!-- DATA -->
                <div class="mb-3">
                    <label asp-for="Date" class="form-label"></label>

                    <input asp-for="Date" type="date" class="form-control" />

                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

                <!-- SUBTOTAL -->
                <div class="mb-3">
                    <label asp-for="Subtotal" class="form-label"></label>

                    <input asp-for="Subtotal" class="form-control" placeholder="0.00" />

                    <span asp-validation-for="Subtotal" class="text-danger"></span>
                </div>

                <!-- IVA -->
                <div class="mb-3">
                    <label asp-for="VATTotal" class="form-label"></label>

                    <input asp-for="VATTotal" class="form-control" placeholder="0.00" />

                    <span asp-validation-for="VATTotal" class="text-danger"></span>
                </div>

                <!-- TOTAL -->
                <div class="mb-3">
                    <label asp-for="Total" class="form-label"></label>

                    <input asp-for="Total" class="form-control" placeholder="0.00" />

                    <span asp-validation-for="Total" class="text-danger"></span>
                </div>

                <hr />
                <h5>Itens da Fatura</h5>

                <table class="table" id="itemsTable">
                    <thead>
                        <tr>
                            <th>Descrição</th>
                            <th>Quantidade</th>
                            <th>Preço</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

                <button type="button" class="btn btn-secondary mt-2" onclick="addRow()">
                    + Adicionar Linha
                </button>

                <br /><br />

                <button type="submit" class="btn btn-success">
                    Criar Fatura
                </button>

                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script>
    let index = 0;

    function addRow() {

        const tableBody = document
            .getElementById("itemsTable")
            .getElementsByTagName("tbody")[0];

        const row = tableBody.insertRow();

        row.innerHTML = `
            <td>
                <input 
                    name="Items[${index}].Description"
                    class="form-control"
                    required />
            </td>

            <td>
                <input 
                    name="Items[${index}].Quantity"
                    type="number"
                    min="1"
                    class="form-control"
                    required />
            </td>

            <td>
                <input 
                    name="Items[${index}].UnitPrice"
                    value="100"
                    class="form-control"
                    required />
            </td>

            <td>
                <button 
                    type="button"
                    class="btn btn-danger"
                    onclick="removeRow(this)">
                    X
                </button>
            </td>
        `;

        index++;
    }

    function removeRow(button) {
        button.closest("tr").remove();
    }
</script>
