@model InvoiceSharp.Models.InvoiceModel

@{
    // Define o título da página (usado no layout)
    ViewData["Title"] = "Criar Fatura";
}

<!-- Container Bootstrap para centralizar conteúdo -->
<div class="container mt-4">

    <!-- Card (caixa visual) -->
    <div class="card shadow">

        <!-- Cabeçalho -->
        <div class="card-header bg-primary text-white">
            <h3>Criar Fatura</h3>
        </div>

        <div class="card-body">

            <!-- ============================= -->
            <!-- FORMULÁRIO MVC               -->
            <!-- ============================= -->
            <!-- asp-controller -> InvoicesController -->
            <!-- asp-action -> método Create -->
            <!-- method POST -> envia dados -->
            <form asp-controller="Invoice" asp-action="Create" method="post">

                <!-- ============================= -->
                <!-- CLIENT ID (FK para Client)   -->
                <!-- ============================= -->
                <div class="mb-3">
                        <label asp-for="ClientId" class="form-label"></label>

                        <select asp-for="ClientId" class="form-control">
                            <option value="">-- Selecionar Cliente --</option>

                            @foreach (var c in ViewBag.Clients)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>

                        <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>


                <!-- ============================= -->
                <!-- DATA DA FATURA               -->
                <!-- ============================= -->
                <div class="mb-3">
                    <label asp-for="Date" class="form-label"></label>

                    <!-- type="date" dá calendário -->
                    <input asp-for="Date"
                           type="date"
                           class="form-control" />

                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>


                <!-- ============================= -->
                <!-- SUBTOTAL                     -->
                <!-- ============================= -->
                <!-- ⚠️ NOTA: no futuro será calculado automaticamente -->
                <div class="mb-3">
                    <label asp-for="Subtotal" class="form-label"></label>

                    <input asp-for="Subtotal"
                           class="form-control"
                           placeholder="0.00" />

                    <span asp-validation-for="Subtotal" class="text-danger"></span>
                </div>


                <!-- ============================= -->
                <!-- IVA (VAT)                    -->
                <!-- ============================= -->
                <!-- ⚠️ Será calculado no backend -->
                <div class="mb-3">
                    <label asp-for="VATTotal" class="form-label"></label>

                    <input asp-for="VATTotal"
                           class="form-control"
                           placeholder="0.00" />

                    <span asp-validation-for="VATTotal" class="text-danger"></span>
                </div>


                <!-- ============================= -->
                <!-- TOTAL                        -->
                <!-- ============================= -->
                <!-- ⚠️ Resultado final (futuro: automático) -->
                <div class="mb-3">
                    <label asp-for="Total" class="form-label"></label>

                    <input asp-for="Total"
                           class="form-control"
                           placeholder="0.00" />

                    <span asp-validation-for="Total" class="text-danger"></span>
                </div>

                <!-- ========================================= -->
                <!-- SECÇÃO: ITENS DA FATURA -->
                <!-- Aqui vamos adicionar linhas dinamicamente -->
                <!-- ========================================= -->

                <hr />

                <h5>Itens da Fatura</h5>

                <!-- Tabela onde vão aparecer os itens -->
                <table class="table" id="itemsTable">
    
                    <!-- Cabeçalho da tabela -->
                    <thead>
                        <tr>
                            <th>Descrição</th>
                            <th>Quantidade</th>
                            <th>Preço</th>
                            <th></th> <!-- coluna para botão remover -->
                        </tr>
                    </thead>

                    <!-- Corpo da tabela (linhas são adicionadas via JS) -->
                    <tbody>
                        <!-- Inicialmente vazio -->
                    </tbody>
                </table>

                <!-- Botão que chama a função JS para adicionar nova linha -->
                <button type="button" class="btn btn-secondary mt-2" onclick="addRow()">
                    + Adicionar Linha
                </button>

                <!-- ============================= -->
                <!-- BOTÃO                        -->
                <!-- ============================= -->
                <!-- Submete o formulário -->
                <button type="submit" class="btn btn-success">
                    Criar Fatura
                </button>

            </form>

        </div>
    </div>

</div>


<!-- ============================= -->
<!-- VALIDAÇÃO CLIENT-SIDE         -->
<!-- ============================= -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}



<script>

    // Índice para identificar cada item da lista
    // Isto é CRÍTICO para o ASP.NET perceber a lista (Items[0], Items[1], etc)
    let index = 0;

    // =========================================
    // FUNÇÃO: addRow()
    // Adiciona uma nova linha à tabela
    // =========================================
    function addRow() {

        // Vai buscar o corpo da tabela
        const tableBody = document
            .getElementById("itemsTable")
            .getElementsByTagName("tbody")[0];

        // Cria uma nova linha (<tr>)
        const row = tableBody.insertRow();

        // Define o conteúdo da linha
        row.innerHTML = `
            
            <!-- DESCRIÇÃO -->
            <td>
                <input 
                    name="Items[${index}].Description" 
                    class="form-control" 
                    placeholder="Produto..." />
            </td>

            <!-- QUANTIDADE -->
            <td>
                <input 
                    name="Items[${index}].Quantity" 
                    type="number" 
                    class="form-control" 
                    placeholder="Qtd" />
            </td>

            <!-- PREÇO -->
            <td>
                <input 
                    name="Items[${index}].Price" 
                    type="number" 
                    step="0.01"
                    class="form-control" 
                    placeholder="Preço" />
            </td>

            <!-- BOTÃO REMOVER -->
            <td>
                <button 
                    type="button" 
                    class="btn btn-danger"
                    onclick="removeRow(this)">
                    X
                </button>
            </td>
        `;

        // Incrementa o índice para próxima linha
        index++;
    }

    // =========================================
    // FUNÇÃO: removeRow(button)
    // Remove a linha clicada
    // =========================================
    function removeRow(button) {

        // Vai ao elemento <tr> mais próximo e remove-o
        button.closest("tr").remove();
    }

</script>