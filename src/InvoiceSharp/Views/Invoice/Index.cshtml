@model IEnumerable<InvoiceSharp.Models.InvoiceModel>

@{
    ViewData["Title"] = "Lista de Faturas";
}

<div class="container mt-4">

    <div class="card shadow">

        <!-- Cabeçalho -->
        <div class="card-header bg-primary text-white">
            <h3>Faturas</h3>
        </div>

        <div class="card-body">

            <!-- Botão criar -->
            <a asp-controller="Invoice"
               asp-action="Create"
               class="btn btn-success mb-3">

                + Nova Fatura
            </a>

            <!-- Tabela -->
            <table class="table table-striped table-hover">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Data</th>
                        <th>Total</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        @foreach (var invoice in Model)
                        {
                            <tr>

                                <!-- ID -->
                                <td>
                                    @invoice.Id
                                </td>

                                <!-- Cliente -->
                                <td>
                                    @invoice.Client?.Name
                                </td>

                                <!-- Data -->
                                <td>
                                    @invoice.Date.ToShortDateString()
                                </td>

                                <!-- Total -->
                                <td>
                                    @invoice.Total €
                                </td>

                                <!-- Botões -->
                                <td>

                                    <!-- Detalhes -->
                                    <a asp-controller="Invoice"
                                       asp-action="Details"
                                       asp-route-id="@invoice.Id"
                                       class="btn btn-primary btn-sm">

                                        Ver
                                    </a>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                Nenhuma fatura encontrada.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>